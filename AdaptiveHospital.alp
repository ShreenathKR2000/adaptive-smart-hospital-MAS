			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1763407316642</Id>
					<Name><![CDATA[logArrival]]></Name>
					<X>240</X><Y>60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[// Simple Java I/O to write the data to a CSV file.
// The file is created in the project root folder.
try {
  // 'true' means append to the file if it exists
  java.io.FileWriter fw = new java.io.FileWriter("arrivals.csv", true);

  // Write the data: Arrival Time, Patient ID, and Patient's Triage Level
  // We use p.getId() which is a unique number automatically assigned by AnyLogic.
  fw.write(p.arrivalTime + "," + p.getId() + "," + p.triageLevel + "\n");
  
  fw.close(); // Important: always close the writer to ensure data is saved
} catch (Exception e) { 
  e.printStackTrace(); 
  // If an error occurs (e.g., file access denied), it prints to the console.
}]]></Body>
				</Function>

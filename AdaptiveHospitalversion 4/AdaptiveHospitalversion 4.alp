			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1763407316642</Id>
					<Name><![CDATA[logArrival]]></Name>
					<X>240</X><Y>60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[try {
    java.io.FileWriter fw = new java.io.FileWriter("arrivals.csv", true);

    // Collect resource IDs safely
    String docID = (p.assignedDoctor != null) ? String.valueOf(p.assignedDoctor.getId()) : "";
    String nurseID = (p.assignedNurse != null) ? String.valueOf(p.assignedNurse.getId()) : "";
    String bedID = (p.assignedBed != null) ? String.valueOf(p.assignedBed.getId()) : "";
    String xrayID = (p.assignedXray != null) ? String.valueOf(p.assignedXray.getId()) : "";

    // Current simulation hour
    int simHour = (int)(time() % 24);

    // Write all info
    fw.write(
        p.arrivalTime + "," +
        p.getId() + "," +
        p.triageLevel + "," +
        p.useDoctor + "," +
        p.useNurse + "," +
        p.useBed + "," +
        p.useXray + "," +
        docID + "," +
        nurseID + "," +
        bedID + "," +
        xrayID + "," +
        simHour + "\n"
    );

    fw.close();

} catch (Exception e) {
    e.printStackTrace();
}
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1767461232794</Id>
					<Name><![CDATA[hourofDay]]></Name>
					<X>240</X><Y>100</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[return (int) (time() % 24);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[boolean]]></ReturnType>
					<Id>1767461299028</Id>
					<Name><![CDATA[isSunday]]></Name>
					<X>240</X><Y>140</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[int day = (int) (time() / 24) % 7;
return day == 6; // 0=Mon ... 6=Sunday]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1767477338035</Id>
					<Name><![CDATA[Debug]]></Name>
					<X>400</X><Y>40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[try {
    java.io.FileWriter fw = new java.io.FileWriter("Debug.csv", true);

    // Current simulation hour
    int simHour = (int)(time() % 24);

    // Write all info
    fw.write(
        Nurseon + "," +
        Doctoron + "," +
        Xrayon + "," +
        Bedon + "," +
        isunday + "\n"
    );

    fw.close();

} catch (Exception e) {
    e.printStackTrace();
}
]]></Body>
				</Function>
			</Functions>
			<Schedules>
				<Schedule>
					<Id>1767484069133</Id>
					<Name><![CDATA[Doctorschedule]]></Name>
					<X>630</X><Y>210</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<ValueType>integer</ValueType>
					<UnitType><![CDATA[NONE]]></UnitType>
					<DefaultValue>0</DefaultValue>
					<RepresentationMode>intervals</RepresentationMode>
					<RepresentationType>week</RepresentationType>
					<FirstDayOfWeek>sunday</FirstDayOfWeek>

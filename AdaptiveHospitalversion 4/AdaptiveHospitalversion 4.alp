			<Functions>
				<Function AccessType="public" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1767213912901</Id>
					<Name><![CDATA[assignStaff]]></Name>
					<X>220</X><Y>40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[    p.useDoctor = false;
    p.useNurse  = false;
    p.useXray   = false;
    p.useBed    = false;

    if (p.triageLevel >= 4) {
        p.useDoctor = true;
        p.useNurse  = true;
        p.useBed    = true;
        if (p.needsXray) p.useXray = true;
    }
    else if (p.triageLevel <= 2) {
        if (p.needsNurse) p.useNurse = true;
        if (p.needsDoctor) p.useDoctor = true;
        if (p.needsXray) p.useXray = true;
    }
    else {
        p.useDoctor = p.needsDoctor;
        p.useNurse  = p.needsNurse;
        p.useXray   = p.needsXray;
    }

    // Compute bids AFTER decision
    if (p.useDoctor) computeDoctorBid(p);
    if (p.useNurse)  computeNurseBid(p);
    if (p.useXray)   computeXrayBid(p);
    if (p.useBed)    computeBedBid(p);
]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[Doctor]]></ReturnType>
					<Id>1767449375421</Id>
					<Name><![CDATA[computeDoctorBid]]></Name>
					<X>40</X><Y>90</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[double urgency = 6 - p.triageLevel;   // triage 5 → 1 (best)

    // Minor patients less urgent
    if (p.triageLevel <= 2) {
        urgency += 2.0;
    }

    // Small randomness to avoid ties
    double randomness = uniform(0, 0.5);

    p.doctorPriority = urgency + randomness;]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[Nurse]]></ReturnType>
					<Id>1767451555820</Id>
					<Name><![CDATA[computeNurseBid]]></Name>
					<X>40</X><Y>180</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[double urgency = 6 - p.triageLevel;

    // Nurses handle many minor cases → slightly higher priority
    if (p.triageLevel <= 2) {
        urgency -= 0.5;
    }

    double randomness = uniform(0, 0.5);

    p.nursePriority = urgency + randomness;]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[Equipment]]></ReturnType>
					<Id>1767451556942</Id>
					<Name><![CDATA[computeXrayBid]]></Name>
					<X>40</X><Y>260</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[  if (!p.needsXray) {
        p.xrayPriority = Double.POSITIVE_INFINITY;
        return;
    }

    double urgency = 6 - p.triageLevel;

    // X-ray mostly important for serious cases
    if (p.triageLevel <= 2) {
        urgency += 1.5;
    }

    double randomness = uniform(0, 0.5);

    p.xrayPriority = urgency + randomness;

]]></Body>
				</Function>
				<Function AccessType="private" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[Equipment]]></ReturnType>
					<Id>1767451557562</Id>
					<Name><![CDATA[computeBedBid]]></Name>
					<X>40</X><Y>220</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[p]]></Name>
						<Type><![CDATA[Patient]]></Type>
					</Parameter>
					<Body><![CDATA[    // Only serious cases get beds
    if (p.triageLevel < 4) {
        p.bedPriority = Double.POSITIVE_INFINITY;
        return;
    }

    double urgency = 6 - p.triageLevel;

    // Beds are critical → strong priority
    double randomness = uniform(0, 0.2);

    p.bedPriority = urgency + randomness;
]]></Body>
				</Function>

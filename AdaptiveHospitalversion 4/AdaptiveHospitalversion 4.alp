	<JavaClasses>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1767448994100</Id>
			<Name><![CDATA[Task]]></Name>
			<Text><![CDATA[public class Task {
    public Patient patient;
    public String taskType;      // e.g., "Consultation", "XRayHelp"
    public int triageLevel;      // urgency
    public double bidValue;      // set by agent during bidding

    public Task(Patient p, String type, int level) {
        this.patient = p;
        this.taskType = type;
        this.triageLevel = level;
        this.bidValue = 0;
    }
}
}

]]></Text>
		</JavaClass>
